{
  "name": "viatutela",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "typecheck": "wrangler types && react-router typegen && tsc -b",
    "test": "vitest run",
    "deploy": "wrangler deploy",
    "preview": "npm run build && vite preview",
    "cf-typegen": "wrangler types",
    "postinstall": "wrangler types",
    "db:migrate:local": "wrangler d1 migrations apply viatutela --local",
    "db:migrate:remote": "wrangler d1 migrations apply viatutela --remote",
    "db:seed:local": "wrangler d1 execute viatutela --local --file=./scripts/seed.sql"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@types/qrcode": "^1.5.6",
    "fflate": "^0.8.3",
    "hono": "^4.7.0",
    "isbot": "^5.1.36",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router": "8.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1",
    "@react-router/dev": "8.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^22.20.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vitest": "^4.1.10",
    "wrangler": "^4.112.0"
  }
}
